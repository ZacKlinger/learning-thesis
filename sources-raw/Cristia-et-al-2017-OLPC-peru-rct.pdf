    <li class='author' style='margin-bottom:0.5em; '>
         Ana Santiago    </li>
    <li class='author' style='margin-bottom:0.5em; '>
         Eugenio Severín    </li>

    </ul>

		<div style='margin-top:25px;'>

			<div class='journal'>American Economic Journal: Applied Economics </div>

			                <div class="journal">
                    <a href="/issues/470" style="color:inherit !important;">
					vol. 9,
					no. 3, 					July 2017					</a>
				</div>

		</div>
                <div class="pages">(pp. 295&ndash;320)</div>
		
    
	
